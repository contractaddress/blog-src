---
import '../../styles/global.css';
import '../../styles/elements.css';
import { getCollection } from 'astro:content';
import TopBar from '../../components/TopBar.astro'

const allPosts = await getCollection('blog');
const published = allPosts.filter(p => !p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const drafts = allPosts.filter(p => p.data.draft).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Writings — Fenghuang</title>
  </head>
  <body>
    <TopBar /> 
    <div class="page-layout">
      <header class="blog-header">
        <a href="/" class="back-link">← home</a>
        <h1 class="page-title">writings</h1>
      </header>

      <div class="posts">
        {published.map(post => (
          <a href={`/blog/${post.id.replace(/\.(md|mdx)$/, '')}`} class="post-card">
            <div class="card-content">
              <h2 class="card-title">{post.data.title}</h2>
              <p class="card-excerpt">{post.data.excerpt}</p>
              <time class="card-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </div>
            {post.data.coverImage && (
              <div class="card-image">
                <img src={post.data.coverImage} alt="" aria-hidden="true" />
              </div>
            )}
          </a>
        ))}

        {drafts.map(post => (
          <div class="post-card coming-soon">
            <div class="card-content">
              <h2 class="card-title dimmed">{post.data.title}</h2>
              <p class="card-excerpt dimmed">{post.data.excerpt}</p>
              <time class="card-date dimmed" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              <span class="soon-badge">COMING SOON</span>
            </div>
            <div class="card-image placeholder">
              <img src="/cover-placeholder.svg" alt="" aria-hidden="true" />
            </div>
          </div>
        ))}
      </div>
    </div>
    <div class='bottom-text-div'>
      <p class='bottom-text'>site and posts written by a human</p>
    </div>
  </body>
</html>

<style is:global>
  .blog-layout {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .bottom-text {
    position: absolute;
    bottom: 1.5rem;
    font-size: 16px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--muted);
  }

  .bottom-text:hover {
    color: var(--accent);
  }

  .post-card {
    display: flex;
    align-items: stretch;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid #222;
    text-decoration: none;
    cursor: pointer;
    transition: padding-left 0.2s ease;
    position: relative;
  }

  a.post-card {
    max-height: 200px
  }

  .post-card:hover {
    padding-left: 0.75rem;
  }

  .post-card:hover::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--accent);
  }

  .post-card.coming-soon {
    cursor: default;
  }

  .post-card.coming-soon:hover {
    padding-left: 0;
  }

  .post-card.coming-soon:hover::before {
    display: none;
  }

  .card-content {
    flex: 0 0 65%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin-top: 30px;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: normal;
    color: var(--text);
    margin-bottom: 0.4rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-card:not(.coming-soon):hover .card-title {
    color: var(--accent);
  }

  .card-title.dimmed {
    color: #333;
  }

  .card-excerpt {
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .card-excerpt.dimmed {
    color: #2a2a2a;
  }

  .card-date {
    font-size: 0.7rem;
    color: var(--muted);
    font-family: var(--font);
    margin-top: auto;

  }

  .card-date.dimmed {
    color: #2a2a2a;
  }

  .soon-badge {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #333;
    border: 1px solid #222;
    padding: 0.2rem 0.5rem;
  }

  .card-image {
    flex: 0 0 35%;
    min-height: 140px;
    overflow: hidden;
    clip-path: polygon(8% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-image.placeholder img {
    opacity: 0.5;
  }


/* for phones  */
@media (max-width: 480px) {
  .blog-layout {
    padding: 2rem 1.25rem;
  }
  a.post-card {
    max-height: none;
    padding-bottom: 1.2rem;
  }
  .post-card {
    flex-direction: row;
    gap: 0.75rem;
    max-height: 120px;
  }
  .card-content {
    flex: 1 1 auto;
    order: 1;
    display: flex;
    margin-top: 10px;
    flex-direction: column;
    justify-content: flex-start;
  }
  .card-image {
    flex: 0 0 40%;
    width: 40%;
    min-height: unset;
    order: 2;
  }
  .card-title {
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }
  .card-excerpt {
    font-size: 0.55rem;
    margin-bottom: 0.25rem;
  }
  .card-date {
    font-size: 0.65rem;
    margin-top: auto;
  }
  .bottom-text {
    font-size: 10px;
  }
}
</style>
