---
import '../styles/global.css';
import fs from 'node:fs';

const asciiArt = fs.readFileSync('public/fenghuang.txt', 'utf-8');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>404 — Fenghuang</title>
  </head>
  <body>
    <main class="not-found">
      <pre class="ascii">{asciiArt}</pre>
      <p class="message">
        Page not found head back <a href="/" class="link">home</a>
      </p>
    </main>
  </body>
</html>

<style is:global>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
  }

  .ascii {
    font-family: 'Mononoki Nerd Font', monospace;
    font-size: clamp(0.30rem, 1.5vw, 0.7rem);
    line-height: 1.1;
    color: var(--accent);
    text-align: center;
    white-space: pre;
    margin-bottom: 2rem;
  }

  .message {
    margin-left: 19px;
    font-size: 0.85rem;
    color: var(--muted);
    font-family: var(--font);
  }

  .link {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .link:hover {
    color: var(--accent);
  }
</style>
