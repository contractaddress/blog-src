---
import '../styles/global.css';
import fs from 'node:fs';

const asciiArt = fs.readFileSync('public/bird.txt', 'utf-8');
const githubIcon = fs.readFileSync('public/github.svg', 'utf-8');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Fenghuang</title>
  </head>
  <body>
    <main class="landing">
      <p class="welcome">welcome to my grey loot blog - Fenghuang</p>
      <pre class="ascii">{asciiArt}</pre>
      <a href="/blog" class="cta">Enter the archive</a>
      <a href="https://github.com/contractaddress/blog-src" class="github-link" aria-label="GitHub" set:html={githubIcon}></a>
    </main>
  </body>
</html>

<style is:global>
  .landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 2rem 4rem 2rem;
    position: relative;
  }

  .welcome {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    margin-right: 20px;
    opacity: 0;
    animation: fadeIn 1s ease 0s forwards;
  }

  .ascii {
    font-family: 'Mononoki', monospace;
    font-size: clamp(0.3rem, 1.3vw, 0.70rem);
    margin-right: 20px;
    line-height: 1.15;
    color: var(--accent);
    text-align: center;
    white-space: pre;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeIn 1.2s ease 0.2s forwards;
  }

  .cta {
    display: inline-block;
    border: 1px solid #e8e8e8;
    padding: 0.8rem 1rem;
    color: #e8e8e8;
    font-family: 'Mononoki', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s ease;
    opacity: 0;
    animation: fadeIn 1s ease 0.8s forwards;
  }

  .cta:hover {
    background: #e8e8e8;
    color: #0a0a0a;
  }

  .github-link {
    position: absolute;
    bottom: 0.5rem;
    margin-top: 20px;
    color: #555;
    transition: color 0.2s ease;
    opacity: 0;
    animation: fadeIn 1s ease 1.2s forwards;
  }

  .github-link:hover {
    color: #e8e8e8;
  }

  @media (max-width: 480px) {
    .ascii {
      font-size: clamp(0.43em, 2.5vw, 0.27rem);
    }
    .cta {
      margin-top: 70px;
    }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }
</style>
