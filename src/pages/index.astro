---
import '../styles/global.css';
import fs from 'node:fs';

const asciiArt = fs.readFileSync('public/bird.txt', 'utf-8');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Fenghuang</title>
  </head>
  <body>
    <main class="landing">
      <p class="welcome">welcome to my blog - Fenghuang</p>
      <pre class="ascii">{asciiArt}</pre>
      <a href="/blog" class="cta">Enter the archive</a>
      <a href="https://github.com/contractaddress" class="github-link" aria-label="GitHub">
        <svg width="25" height="25" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
    </main>
  </body>
</html>

<style is:global>
  .landing {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 2rem 4rem 2rem;
    position: relative;
  }

  .welcome {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--muted);
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: fadeIn 1s ease 0s forwards;
  }

  .ascii {
    font-family: 'Mononoki Nerd Font', monospace;
    font-size: clamp(0.3rem, 1.3vw, 0.70rem);
    margin-right: 20px;
    line-height: 1.15;
    color: var(--accent);
    text-align: center;
    white-space: pre;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeIn 1.2s ease 0.2s forwards;
  }

  .cta {
    display: inline-block;
    border: 1px solid #e8e8e8;
    padding: 0.8rem 1rem;
    color: #e8e8e8;
    font-family: 'Mononoki Nerd Font', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.2s ease;
    opacity: 0;
    animation: fadeIn 1s ease 0.8s forwards;
  }

  .cta:hover {
    background: #e8e8e8;
    color: #0a0a0a;
  }

  .github-link {
    position: absolute;
    bottom: 0.5rem;
    margin-top: 20px;
    color: #555;
    transition: color 0.2s ease;
    opacity: 0;
    animation: fadeIn 1s ease 1.2s forwards;
  }

  .github-link:hover {
    color: #e8e8e8;
  }

  @media (max-width: 480px) {
    .ascii {
      font-size: clamp(0.43em, 2.5vw, 0.27rem);
    }
    .cta {
      margin-top: 70px;
    }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }
</style>
